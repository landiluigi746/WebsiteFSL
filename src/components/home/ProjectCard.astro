---
import { type ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { type ProjectMetadata } from "../../data/projects";

interface Props {
    project: ProjectMetadata;
}

const { project } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/images/home/copertine/*.png",
);
---

<a href={project.route}>
    <div
        class="flex flex-col gap-2 p-2 rounded-lg bg-zinc-200 shadow-sm shadow-zinc-500 transition-all hover:bg-zinc-300 hover:shadow-lg hover:-translate-y-2 hover:cursor-pointer"
    >
        <Image
            src={images[project.imgPath]()}
            alt={`${project.title} - Copertina`}
            class="aspect-video w-full h-auto bg-neutral-600 rounded-lg"
        />
        <h3 class="text-xl font-semibold md:text-2xl">
            {project.title}
        </h3>
        <div
            class="flex flex-row items-center justify-start gap-2 not-lg:flex-wrap"
        >
            {
                project.years.map((year) => (
                    <p class="text-sm px-1.5 py-0.5 rounded-lg bg-zinc-50 lg:px-2 lg:py-1 ">
                        {year}
                    </p>
                ))
            }
        </div>
        <p class="max-w-full text-sm">
            {project.shortDescription}
        </p>
    </div>
</a>
