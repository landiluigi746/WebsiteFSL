---
import { Image } from "astro:assets";
import background from "../../images/home/sfondo.png";
---

<div class="h-screen flex flex-col items-center justify-center gap-2">
    <h1 class="text-4xl font-extrabold md:text-6xl">Portfolio FSL</h1>
    <h2 class="text-xl md:text-4xl">Luigi Landi 5G</h2>
    <h3 class="text-center font-bold md:text-lg">
        IIS Margherita Hack Baronissi<br />2023-2026
    </h3>
</div>
<Image
    src={background}
    alt="Sfondo hero section"
    class="-z-10 absolute top-0 left-0 w-svw h-svh opacity-15 object-cover"
/>
