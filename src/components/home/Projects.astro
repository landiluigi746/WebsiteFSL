---
import { projects, type Project } from "../../data/projects";
---

<div class="flex flex-col items-center justify-center gap-12 py-32">
    <h2 class="text-4xl">Progetti realizzati</h2>
    <div class="grid grid-cols-3 items-center justify-center gap-4">
        {
            projects.map((project: Project) => (
                <div class="max-w-80 flex flex-col gap-2 p-2 rounded-xl bg-zinc-200 shadow-sm shadow-zinc-500 transition-all hover:bg-zinc-300 hover:shadow-lg hover:-translate-y-2 hover:cursor-pointer">
                    <div class="aspect-video w-full h-auto bg-neutral-600 rounded-xl" />
                    <h3 class="text-2xl">{project.title}</h3>
                    <div class="flex flex-row items-center justify-start gap-2">
                        {project.years.map((year) => (
                            <p class="px-2 py-1 rounded-xl bg-zinc-50">
                                {year}
                            </p>
                        ))}
                    </div>
                    <p class="max-w-full text-sm">{project.description}</p>
                </div>
            ))
        }
    </div>
</div>
